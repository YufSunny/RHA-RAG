    "from zai import ZhipuAiClient\n",
    "from pathlib import Path\n",
    "# 初始化客户端\n",
    "client = ZhipuAiClient(api_key=\"your-api-key\")\n",
    "\n",
    "\n",
    "# 调用布局解析 API\n",
    "response = client.layout_parsing.create(\n",
    "    model=\"glm-ocr\",\n",
    "    file=Path(\"../data/local/...\")\n",
    ")\n",
    "\n",
    "# 输出结果\n",
    "print(response.md_results)"
   ]
  }
