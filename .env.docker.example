# Copy this file to .env and fill in your API keys before running:
#   docker compose --env-file .env up --build

# ── Required ──────────────────────────────────────────────────
ZAI_API_KEY=your-zai-key-here
QWEN_API_KEY=your-qwen-key-here
OPENAI_API_KEY=your-deepseek-key-here

# ── Optional — model configuration (defaults shown) ───────────
# LLM_MODEL=deepseek-v4-pro
# LLM_BASE_URL=https://api.deepseek.com
# EMBED_MODEL=text-embedding-v4
# EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OCR_MODEL=glm-ocr
# LLM_THINKING=true              # set to false to disable thinking mode
# LLM_REASONING_EFFORT=high       # low | medium | high | xhigh | max
